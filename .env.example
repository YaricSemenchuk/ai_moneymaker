# Telegram API (получить на https://my.telegram.org/apps)
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=your_api_hash_here

# OpenRouter API (получить на https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# OpenRouter модель (бесплатные: meta-llama/llama-2-7b-chat, mistralai/mistral-7b-instruct)
OPENROUTER_MODEL=meta-llama/llama-2-7b-chat

# Реферальная ссылка на ваш проект
REFERRAL_BOT=@moneymakerquest_bot

# Режим логирования (INFO, DEBUG)
LOG_LEVEL=INFO

# Путь к БД
DB_PATH=moneymaker_agent.db
