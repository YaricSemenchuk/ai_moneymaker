# Telegram API (получить на https://my.telegram.org/apps)
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=your_api_hash_here

# OpenRouter API (получить на https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# OpenRouter модель (бесплатные: meta-llama/llama-2-7b-chat, mistralai/mistral-7b-instruct)
OPENROUTER_MODEL=meta-llama/llama-2-7b-chat

# Реферальная ссылка на ваш проект
REFERRAL_BOT=@moneymakerquest_bot

# Режим логирования (INFO, DEBUG)
LOG_LEVEL=INFO

# Путь к БД и сессиям.
# Локально оставь относительные пути. На Railway — оба должны лежать на Volume:
#   DB_PATH=/data/moneymaker_agent.db
#   SESSIONS_DIR=/data/sessions
DB_PATH=moneymaker_agent.db
SESSIONS_DIR=sessions

# ----- Dashboard / Mini App -----
# BOT_TOKEN: токен Telegram-бота, через который открывается Mini App
# (нужен для верификации initData по HMAC).
BOT_TOKEN=
# ALLOWED_USER_IDS: список telegram user_id через запятую, кто имеет доступ
# к дашборду. Свой id узнать через @userinfobot.
ALLOWED_USER_IDS=

# ----- Admin alerts (опционально) -----
# Отдельный бот, в который шлются алерты о банах/проблемах.
ADMIN_BOT_TOKEN=
ADMIN_CHAT_ID=

# ----- Signup attribution -----
# Общий секрет между этим дашбордом и @moneymakerquest_bot.
# Используется для подписи запросов POST /api/track-signup.
# Сгенерировать: python -c "import secrets;print(secrets.token_hex(32))"
TRACK_SECRET=

# Публичный URL дашборда (используется в deeplink-генерации, если надо).
DASHBOARD_PUBLIC_URL=
